    <title>PostgreSQL 索引与性能调优</title>
    <link href="/2026/04/05/postgresql-performance-index/"/>
    <url>/2026/04/05/postgresql-performance-index/</url>
    
    <content type="html"><![CDATA[<h1 id="PostgreSQL-性能优化"><a href="#PostgreSQL-性能优化" class="headerlink" title="PostgreSQL 性能优化"></a>PostgreSQL 性能优化</h1><h2 id="GIN-索引"><a href="#GIN-索引" class="headerlink" title="GIN 索引"></a>GIN 索引</h2><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs sql"><span class="hljs-keyword">CREATE</span> INDEX idx_posts_tags <span class="hljs-keyword">ON</span> posts <span class="hljs-keyword">USING</span> GIN(tags);<br></code></pre></td></tr></table></figure><h2 id="部分索引"><a href="#部分索引" class="headerlink" title="部分索引"></a>部分索引</h2><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs sql"><span class="hljs-keyword">CREATE</span> INDEX idx_active <span class="hljs-keyword">ON</span> users(email) <span class="hljs-keyword">WHERE</span> deleted_at <span class="hljs-keyword">IS</span> <span class="hljs-keyword">NULL</span>;<br></code></pre></td></tr></table></figure><h2 id="EXPLAIN-ANALYZE"><a href="#EXPLAIN-ANALYZE" class="headerlink" title="EXPLAIN ANALYZE"></a>EXPLAIN ANALYZE</h2><figure class="highlight sql"><table><tr><td class="gutter"><pre><span class="line">1</span><br></pre></td><td class="code"><pre><code class="hljs sql">EXPLAIN ANALYZE <span class="hljs-keyword">SELECT</span> <span class="hljs-operator">*</span> <span class="hljs-keyword">FROM</span> posts <span class="hljs-keyword">WHERE</span> published<span class="hljs-operator">=</span><span class="hljs-literal">true</span> <span class="hljs-keyword">ORDER</span> <span class="hljs-keyword">BY</span> created_at <span class="hljs-keyword">DESC</span> LIMIT <span class="hljs-number">20</span>;<br></code></pre></td></tr></table></figure>]]></content>
    
    
