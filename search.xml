    <title>PostgreSQL 索引与性能调优</title>
    <url>/2026/04/05/postgresql-performance-index/</url>
    <content><![CDATA[<h1 id="PostgreSQL-性能优化"><a href="#PostgreSQL-性能优化" class="headerlink" title="PostgreSQL 性能优化"></a>PostgreSQL 性能优化</h1><h2 id="GIN-索引"><a href="#GIN-索引" class="headerlink" title="GIN 索引"></a>GIN 索引</h2><figure class="highlight sql"><table><tr><td class="code"><pre><span class="line"><span class="keyword">CREATE</span> INDEX idx_posts_tags <span class="keyword">ON</span> posts <span class="keyword">USING</span> GIN(tags);</span><br></pre></td></tr></table></figure>

<h2 id="部分索引"><a href="#部分索引" class="headerlink" title="部分索引"></a>部分索引</h2><figure class="highlight sql"><table><tr><td class="code"><pre><span class="line"><span class="keyword">CREATE</span> INDEX idx_active <span class="keyword">ON</span> users(email) <span class="keyword">WHERE</span> deleted_at <span class="keyword">IS</span> <span class="keyword">NULL</span>;</span><br></pre></td></tr></table></figure>

<h2 id="EXPLAIN-ANALYZE"><a href="#EXPLAIN-ANALYZE" class="headerlink" title="EXPLAIN ANALYZE"></a>EXPLAIN ANALYZE</h2><figure class="highlight sql"><table><tr><td class="code"><pre><span class="line">EXPLAIN ANALYZE <span class="keyword">SELECT</span> <span class="operator">*</span> <span class="keyword">FROM</span> posts <span class="keyword">WHERE</span> published<span class="operator">=</span><span class="literal">true</span> <span class="keyword">ORDER</span> <span class="keyword">BY</span> created_at <span class="keyword">DESC</span> LIMIT <span class="number">20</span>;</span><br></pre></td></tr></table></figure>]]></content>
